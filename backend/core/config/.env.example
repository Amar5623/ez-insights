# =============================================================================
# .env.example — NL-SQL backend configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp core/config/.env.example .env
#
# NEVER commit .env to git — it is in .gitignore.
# Every key added to settings.py MUST be documented here.
# Lead owns both files.
# =============================================================================


# =============================================================================
# LLM PROVIDER
# Which LLM to use for SQL generation and answer generation.
# Options: groq | gemini | ollama
# =============================================================================

LLM_PROVIDER=groq

# --- Groq (default — free, fast, OpenAI-compatible) ---
# Free tier: https://console.groq.com
# Best models for SQL:
#   llama-3.3-70b-versatile  — best quality, still very fast
#   llama-3.1-8b-instant     — fastest, good for simple queries
#   mixtral-8x7b-32768       — large context window for big schemas
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---
# Free tier: 1500 req/day on Flash — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (local, no API key needed) ---
# Install: https://ollama.com — then: ollama pull llama3
# Good SQL models locally: codellama, llama3, mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3


# =============================================================================
# EMBEDDER PROVIDER
# IMPORTANT: This is separate from the LLM above.
# The embedder converts schema text and questions to vectors for RAG search.
# You can combine any LLM with any embedder — e.g. Groq + OpenAI embeddings.
# Options: openai | cohere
# =============================================================================

EMBEDDER_PROVIDER=openai

# --- OpenAI embedder (default) ---
# NOTE: This OPENAI_API_KEY is used ONLY for embeddings, not for LLM generation.
# Even if LLM_PROVIDER=groq, you still need this if EMBEDDER_PROVIDER=openai.
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Cohere embedder ---
# Required when EMBEDDER_PROVIDER=cohere
COHERE_API_KEY=...
COHERE_EMBEDDING_MODEL=embed-english-v3.0


# =============================================================================
# DATABASE — Options: mysql | mongo
# =============================================================================

DB_TYPE=mysql

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=nlsql_db
MYSQL_POOL_SIZE=5

MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=nlsql_db
MONGO_SAMPLE_SIZE=100


# =============================================================================
# VECTOR STORE — Options: faiss | pinecone
# =============================================================================

VECTOR_STORE=faiss

FAISS_INDEX_PATH=./data/faiss_index

PINECONE_API_KEY=...
PINECONE_INDEX=nlsql


# =============================================================================
# QUERY STRATEGY — Options: auto | sql | fuzzy | vector | combined
# =============================================================================

STRATEGY=auto
MAX_RETRIES=3
MAX_RESULT_ROWS=100


# =============================================================================
# API / SERVER
# =============================================================================

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-in-env

CORS_ORIGINS=["http://localhost:5173"]
