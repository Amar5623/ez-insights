# =============================================================================
# .env.example — NL-SQL backend configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp core/config/.env.example .env
#
# NEVER commit .env to git — it is in .gitignore.
# Every key added to settings.py MUST be documented here.
# Lead owns both files.
# =============================================================================


# =============================================================================
# LLM PROVIDER
# Which LLM to use for SQL generation and answer generation.
# Options: groq | gemini | ollama
# =============================================================================

LLM_PROVIDER=groq

# --- Groq (default — free, fast) ---
# Get free key: https://console.groq.com
# Best models for SQL:
#   llama-3.3-70b-versatile  — best quality (recommended)
#   llama-3.1-8b-instant     — fastest, good for simple queries
#   mixtral-8x7b-32768       — large context for big schemas
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---
# Free tier: 1500 req/day — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (local, no API key) ---
# Install: https://ollama.com — then: ollama pull llama3
# Good SQL models: codellama, llama3, mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3


# =============================================================================
# EMBEDDER PROVIDER
# Converts schema text and questions into vectors for RAG similarity search.
# Options: nomic | cohere
#
# nomic runs through the same Ollama server as the LLM — zero extra setup.
# Just pull the model once: ollama pull nomic-embed-text
# gemma uses google/embeddinggemma-300m from Hugging Face (768 dims, same as nomic)
# =============================================================================

EMBEDDER_PROVIDER=nomic

# --- nomic-embed-text (default — local, free, 768 dims) ---
# Runs via Ollama — no API key needed.
# Pull once: ollama pull nomic-embed-text
# Uses the same OLLAMA_BASE_URL set above.
NOMIC_MODEL=nomic-embed-text

# --- Cohere (cloud alternative — 1024 dims) ---
# Only needed if EMBEDDER_PROVIDER=cohere
# Get key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...
COHERE_EMBEDDING_MODEL=embed-english-v3.0
# --- EmbeddingGemma (Hugging Face — 768 dims, FAISS compatible with nomic) ---
# Only needed if EMBEDDER_PROVIDER=gemma
# PREREQUISITES:
#   1. Accept license: https://huggingface.co/google/embeddinggemma-300m
#   2. Get token: https://huggingface.co/settings/tokens
#   3. Already installed: sentence-transformers (in requirements.txt)
# Dimensions: 768 (same as nomic — no FAISS re-indexing needed when switching)
# Note: Uses encode_query() for questions, encode_document() for schema chunks
HF_TOKEN=hf_...

# =============================================================================
# DATABASE — Options: mysql | mongo
# =============================================================================

DB_TYPE=mysql

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=nlsql_db
MYSQL_POOL_SIZE=5

MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=nlsql_db
MONGO_SAMPLE_SIZE=100


# =============================================================================
# VECTOR STORE — Options: faiss | pinecone
# faiss is local and requires no account — recommended for development.
# =============================================================================

VECTOR_STORE=faiss

FAISS_INDEX_PATH=./data/faiss_index

# Pinecone — only needed if VECTOR_STORE=pinecone
# Dimensions must match embedder: 768 for nomic, 1024 for cohere
PINECONE_API_KEY=...
PINECONE_INDEX=nlsql


# =============================================================================
# QUERY STRATEGY — Options: auto | sql | fuzzy | vector | combined
# auto = router classifies the question and picks the best strategy
# =============================================================================

STRATEGY=auto
MAX_RETRIES=3
MAX_RESULT_ROWS=100


# =============================================================================
# API / SERVER
# =============================================================================

# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-in-env

CORS_ORIGINS=["http://localhost:3000"]



MAX_DB_FETCH_ROWS=100
MAX_ROWS_FOR_LLM=15
PAGE_SIZE=10