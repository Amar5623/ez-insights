# Copy to .env.local — never commit .env.local to git

BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=your-actual-api-key-here

# jwt secret generator run bash :
#openssl rand -base64 48

# New — never use NEXT_PUBLIC_ prefix for these (they'd leak to the browser)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ez_insights
MONGODB_DB_NAME_AUTH=ez_insights_auth
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars